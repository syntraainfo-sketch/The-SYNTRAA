# THE SYNTRAA API — Render / local
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# MongoDB Atlas (required)
MONGODB_URI=mongodb+srv://syntraainfo_db_user:B8gL8qxEZgDEGgUA@cluster.mongodb.net/syntraa?retryWrites=true&w=majority

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES=syntraa-access-secret
JWT_REFRESH_EXPIRES=syntraa-refresh-secret

# Stripe (use test keys in dev; live keys only on production Render service)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Public price display / checkout success redirect base (web origin)
WEB_PUBLIC_URL=http://localhost:3000

# JazzCash (merchant portal — confirm field names with your JazzCash API version)
# Callback URL on Render: https://api.YOUR_DOMAIN.com/api/v1/payments/jazzcash/callback
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=http://localhost:3000/checkout/complete
JAZZCASH_POST_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform

# Easypaisa (confirm with Easypaisa merchant integration guide)
# Callback URL: https://api.YOUR_DOMAIN.com/api/v1/payments/easypaisa/callback
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_POST_URL=https://easypaystg.easypaisa.com.pk/easypay/Index.jsf
EASYPAISA_RETURN_URL=http://localhost:3000/checkout/complete

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=syntraa

# FX helper for PK wallet rails (USD → PKR rough conversion)
PKR_PER_USD=280
